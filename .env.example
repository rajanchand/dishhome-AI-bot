# ════════════════════════════════════════════════════════════════════════════
# DishHome AI Call Center — Environment Configuration
# Copy to `.env` and fill in real secrets before running in production.
# ════════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-strong-random-32-char-string

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8001"]

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dishhome:dishhome_secret@postgres:5432/dishhome_db

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Elasticsearch ───────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── MinIO / S3 ──────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_RECORDINGS=call-recordings
S3_BUCKET_ATTACHMENTS=ticket-attachments

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=jwt-secret-change-to-a-strong-random-string-32-chars-min
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── Ollama LLM ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60

# ── Whisper STT ─────────────────────────────────────────────────────────────
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Edge-TTS ────────────────────────────────────────────────────────────────
TTS_VOICE_NEPALI=ne-NP-SagarNeural
TTS_VOICE_ENGLISH=en-US-AriaNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# ── Huawei iMaster NCE (leave empty for stub mode) ─────────────────────────
HUAWEI_OLT_BASE_URL=http://192.168.1.1:8080
HUAWEI_OLT_USERNAME=admin
HUAWEI_OLT_PASSWORD=

# ── SMS (Sparrow) ───────────────────────────────────────────────────────────
SPARROW_SMS_TOKEN=
SPARROW_SMS_FROM=DishHome

# ── SMTP Email ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@dishhome.com.np
SMTP_FROM_NAME=DishHome Support
SMTP_USE_TLS=true

# ── Payment Gateways ────────────────────────────────────────────────────────
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=
KHALTI_SECRET_KEY=

# ── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
ENABLE_PROMETHEUS=true

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/voicebot.log

# ── Legacy (kept for backward compatibility) ───────────────────────────────
AGENT_USERNAME=admin
AGENT_PASSWORD=dishhome@2024
