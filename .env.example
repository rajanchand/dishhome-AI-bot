# ============================================
# DishHome AI Voice Bot - Environment Config
# ============================================

# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-to-a-secure-random-string

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=30

# Whisper STT Configuration
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# TTS Configuration
TTS_VOICE_NEPALI=ne-NP-SagarNeural
TTS_VOICE_ENGLISH=en-US-AriaNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# Database
DATABASE_URL=sqlite+aiosqlite:///./dishhome_voicebot.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/voicebot.log

# Auth (for agent dashboard)
AGENT_USERNAME=admin
AGENT_PASSWORD=dishhome@2024
